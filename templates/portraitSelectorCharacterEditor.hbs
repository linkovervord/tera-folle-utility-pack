<div class="portrait-selector-character-editor-tfup-pts" style="max-height:60vh; height: auto; overflow-y:auto; overflow-x:hidden;">
  <h2>Character</h2>

  <div style="display: flex; flex-direction:column;">
    <label style="font-weight: bolder">Name</label>
    <p>{{character.name}}</p>

    <label style="font-weight: bolder">ID</label>
    <p>{{character.id}}</p>
  </div>

  <hr />

  <h2>Variants</h2>

  {{#each character.variants}}

    <div class="variant-row-tfup-pts" style="margin-bottom: 16px;" data-index="{{@index}}">

      <div style="display: flex; align-items: center;">

        {{#if path}}
          <img src="{{path}}" class="character-image-preview-tfup-pts" width="60" style="margin-bottom: 4px;" />
        {{/if}}
        <div style="display: flex; flex-direction: column; margin-left: 8px;">

          <label><b>Character Variant Name</b></label>
          <input
            type="text"
            value="{{name}}"
            style="margin-bottom: 4px; width: {{#if path}}604px{{else}}662px{{/if}};"
            class="modify-character-variant-name-tfup-pts"
            data-index="{{@index}}"
          />

          <label><b>Image Path</b></label>
          <input 
            type="text"
            value="{{path}}"
            style="margin-bottom: 4px; width: {{#if path}}604px{{else}}662px{{/if}};"
            class="modify-character-variant-image-path-tfup-pts"
            data-index="{{@index}}"
          />

        </div>

      </div>

      <div style="display:flex; gap: 8px;">
        <button
          type="button"
          class="file-picker-tfup-pts"
          data-index="{{@index}}"

          style="background-color: rgb(0, 74, 185); color:rgb(0, 0, 0));"
        >
          Browse Image
        </button>

        <button
          type="button"
          class="delete-variant-tfup-pts"
          data-index="{{@index}}"
        >
          <b>Delete Variant:</b> {{name}}
        </button>
      </div>
    </div>

  {{/each}}

  <button
    type="button"
    class="add-variant-tfup-pts"
    style="margin-top: 8px; background-color: black; color: white;"
  >
    Add Character Variant
  </button>

  <hr />

  <h2>Companions</h2>

  {{#each character.companions}}

    <div class="companion-row-tfup-pts" style="margin-bottom: 16px;" data-index="{{@index}}">

      <label><b>Name</b></label>
      <input
        type="text"
        value="{{name}}"
        style="margin-bottom: 4px;"
        class="modify-companion-name-tfup-pts"
        data-index="{{@index}}"
      />

      <label><b>ID</b></label>
      <span style="text-align:center;">{{id}}</span>
      <div style="display:flex; gap: 8px;">
        <button
            type="button"
            class="edit-companion-tfup-pts"
            data-index="{{@index}}"
        >
            <b>Edit Variant:</b> {{name}}
        </button>

        <button
            type="button"
            class="delete-companion-tfup-pts"
            data-index="{{@index}}"
        >
            <b>Delete Variant:</b> {{name}}
        </button>
      </div>
    </div>

  {{/each}}

  <button
    type="button"
    class="add-companion-tfup-pts"
    style="margin-top: 8px; background-color: black; color: white;"
  >
    Add Companion
  </button>
</div>