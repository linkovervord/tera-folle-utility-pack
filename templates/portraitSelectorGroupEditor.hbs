<div class="portrait-selector-group-editor-tfup-pts" style="max-height:60vh; height: auto; overflow-y:auto; overflow-x:hidden;">
  <h2>{{group.groupName}} - Characters</h2>

  {{#each group.characters}}

    <div class="character-row-tfup-pts" data-index="{{@index}}" style="display:flex; flex-direction: column; justify-content: center; margin-bottom: 16px;">

      <label><b>Character Name</b></label>
      <input
        type="text"
        value="{{name}}"

        style="margin-bottom: 4px;"
        class="modify-character-name-tfup-pts"
        data-index="{{@index}}"
      />

      <div style="display:flex; gap: 8px;">
          <button type="button" class="edit-character-tfup-pts" data-index="{{@index}}">
            <b>Edit Character:</b> {{name}}
          </button>

          <button type="button" class="delete-character-tfup-pts" data-index="{{@index}}">
            <b>Delete Character:</b> {{name}}
          </button>
      </div>

    </div>

  {{/each}}

  <button type="button" class="add-character-tfup-pts" style="margin-top: 8px; background-color: black; color: white;">
    Add Character
  </button>
</div>
