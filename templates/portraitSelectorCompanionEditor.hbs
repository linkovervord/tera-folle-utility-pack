<div class="portrait-selector-companion-editor-tfup-pts" style="max-height:60vh; height: auto; overflow-y:auto; overflow-x:hidden;">
  <h2>{{companion.name}}</h2>

  {{#each companion.variants}}

    <div class="variant-row-tfup-pts" style="margin-bottom: 16px;" data-index="{{@index}}">

      <div style="display: flex; align-items: center;">

        {{#if path}}
          <img src="{{path}}" width="60" class="companion-image-preview-tfup-pts" style="margin-bottom: 4px;" />
        {{/if}}
        <div style="display: flex; flex-direction: column; margin-left: 8px;">

          <label><b>Companion Variant Name</b></label>
          <input
            type="text"
            value="{{name}}"
            style="margin-bottom: 4px; width: {{#if path}}604px{{else}}662px{{/if}};"
            class="modify-companion-variant-name-tfup-pts"
            data-index="{{@index}}"
          />

          <label><b>Image Path</b></label>
          <input 
            type="text"
            value="{{path}}"
            style="margin-bottom: 4px; width: {{#if path}}604px{{else}}662px{{/if}};"
            class="modify-companion-variant-image-path-tfup-pts"
            data-index="{{@index}}"
          />

        </div>

      </div>

      <div style="display:flex; gap: 8px;">
        <button
          type="button"
          class="file-picker-tfup-pts"
          data-index="{{@index}}"

          style="background-color: rgb(0, 74, 185); color:rgb(0, 0, 0));"
        >
          Browse Image
        </button>

        <button
          type="button"
          class="delete-variant-tfup-pts"
          data-index="{{@index}}"
        >
          <b>Delete Variant:</b> {{name}}
        </button>
      </div>

    </div>

  {{/each}}

  <button type="button" class="add-variant-tfup-pts" style="margin-top: 8px; background-color: black; color: white;">
    Add Companion Variant
  </button>
</div>