<div class="portrait-selector-manager-tfup-pts" style="max-height:60vh; height: auto; overflow-y:auto; overflow-x:hidden;">

  {{#each groups}}
    <div class="group-row-tfup-pts" data-index="{{@index}}" style="display:flex; flex-direction: column; justify-content: center; margin-bottom: 16px;">

      <label><b>Group Name</b></label>
      <input
        type="text"
        value="{{groupName}}"

        style="margin-bottom: 4px;"
        class="modify-group-name-tfup-pts"
        data-index="{{@index}}"
      />

      <div style="display:flex; gap: 8px;">
        <button type="button" class="edit-group-tfup-pts" data-index="{{@index}}">
          <b>Edit Group:</b> {{groupName}}
        </button>

        <button type="button" class="delete-group-tfup-pts" data-index="{{@index}}">
          <b>Delete Group:</b> {{groupName}}
        </button>
      </div>

    </div>
  {{/each}}

  <button type="button" class="add-group-tfup-pts" style="margin-top: 8px; background-color: black; color: white;">
    Add Group
  </button>
</div>